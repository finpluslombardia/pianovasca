import React, { useState, useEffect, useCallback, useMemo } from 'react';
import { Download, Upload, Trash2, Info, Plus, Eraser, Save, Clock } from 'lucide-react';

// --- CONFIGURAZIONE INIZIALE ---
const GIORNI = ['Lunedì', 'Martedì', 'Mercoledì', 'Giovedì', 'Venerdì', 'Sabato', 'Domenica'];
const ORE_INIZIO = 8;  // 08:00
const ORE_FINE = 22;   // 22:00
const NUM_CORSIE = 6;

const ATTIVITA_DI_BASE = [
  { id: 'libero', name: 'Nuoto Libero', color: 'bg-slate-300 text-slate-800', border: 'border-slate-400' },
  { id: 'scuola_bambini', name: 'Scuola Nuoto Bambini', color: 'bg-sky-300 text-sky-900', border: 'border-sky-400' },
  { id: 'scuola_adulti', name: 'Scuola Nuoto Adulti', color: 'bg-green-500 text-white', border: 'border-green-600' },
  { id: 'acquagym', name: 'Acquagym', color: 'bg-fuchsia-500 text-white', border: 'border-fuchsia-600' },
  { id: 'propaganda', name: 'Propaganda', color: 'bg-blue-600 text-white', border: 'border-blue-700' },
  { id: 'privato', name: 'Lez. Privata', color: 'bg-yellow-300 text-yellow-900', border: 'border-yellow-400' },
];

export default function App() {
  // --- STATO DELL'APPLICAZIONE ---
  const [giornoSelezionato, setGiornoSelezionato] = useState(0);
  const [piano, setPiano] = useState({}); // Mappa: "giorno-ora-corsia" -> idAttivita
  const [attivita, setAttivita] = useState(ATTIVITA_DI_BASE);
  const [strumentoAttivo, setStrumentoAttivo] = useState('libero'); // L'attività attualmente selezionata come "pennello"
  const [isDisegnando, setIsDisegnando] = useState(false);
  const [intervallo, setIntervallo] = useState(30); // Imposta gli slot di default a 30 minuti

  // Array di supporto per griglia generati dinamicamente
  const fasceOrarie = useMemo(() => {
    const fasce = [];
    let h = ORE_INIZIO;
    let m = 0;
    while (h < ORE_FINE) {
      const start = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
      let nextM = m + intervallo;
      let nextH = h + Math.floor(nextM / 60);
      nextM = nextM % 60;

      let endH = nextH >= ORE_FINE ? ORE_FINE : nextH;
      let endM = nextH >= ORE_FINE ? 0 : nextM;

      const end = `${String(endH).padStart(2, '0')}:${String(endM).padStart(2, '0')}`;
      fasce.push({ id: start, label: `${start} - ${end}` });

      h = nextH;
      m = nextM;

      if (h >= ORE_FINE) break;
    }
    return fasce;
  }, [intervallo]);

  const corsie = Array.from({ length: NUM_CORSIE }, (_, i) => i + 1);

  // --- LOGICA DI DISEGNO (PENNELATURA) ---
  const applicaStrumento = useCallback((fasciaId, corsia) => {
    const key = `${giornoSelezionato}-${fasciaId}-${corsia}`;
    setPiano(prev => {
      if (strumentoAttivo === 'gomma') {
        const nuovoPiano = { ...prev };
        delete nuovoPiano[key];
        return nuovoPiano;
      } else {
        return { ...prev, [key]: strumentoAttivo };
      }
    });
  }, [giornoSelezionato, strumentoAttivo]);

  const handleMouseDown = (fasciaId, corsia) => {
    setIsDisegnando(true);
    applicaStrumento(fasciaId, corsia);
  };

  const handleMouseEnter = (fasciaId, corsia) => {
    if (isDisegnando) {
      applicaStrumento(fasciaId, corsia);
    }
  };

  // Ferma il disegno se il mouse viene rilasciato ovunque nello schermo
  useEffect(() => {
    const handleMouseUp = () => setIsDisegnando(false);
    window.addEventListener('mouseup', handleMouseUp);
    return () => window.removeEventListener('mouseup', handleMouseUp);
  }, []);

  // --- FUNZIONI DI SALVATAGGIO / CARICAMENTO (JSON) ---
  const esportaDati = () => {
    const dataStr = JSON.stringify({ piano, attivita }, null, 2);
    const blob = new Blob([dataStr], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = "mio_piano_vasca.json";
    link.click();
    URL.revokeObjectURL(url);
  };

  const importaDati = (event) => {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const dati = JSON.parse(e.target.result);
        if (dati.piano) setPiano(dati.piano);
        if (dati.attivita) setAttivita(dati.attivita);
      } catch (error) {
        alert("Errore nel caricamento del file. Assicurati che sia il file JSON corretto.");
      }
    };
    reader.readAsText(file);
    // Reset dell'input
    event.target.value = null;
  };

  const svuotaPiano = () => {
    if (confirm("Sei sicuro di voler cancellare tutto il piano vasca? L'operazione non è reversibile.")) {
      setPiano({});
    }
  };

  // --- RENDER COMPONENTI ---
  const attivitaCorrente = attivita.find(a => a.id === strumentoAttivo);

  return (
    <div className="min-h-screen bg-slate-50 flex flex-col font-sans text-slate-800">
      
      {/* HEADER E CONTROLLI */}
      <header className="bg-white border-b border-slate-200 sticky top-0 z-20 shadow-sm p-4">
        <div className="max-w-7xl mx-auto">
          <div className="flex flex-col md:flex-row justify-between items-center mb-4 gap-4">
            <h1 className="text-2xl font-bold text-slate-800 flex items-center gap-2">
              🌊 Gestione Piano Vasca
            </h1>
            <div className="flex items-center gap-2">
              <button onClick={esportaDati} className="flex items-center gap-2 px-3 py-2 bg-slate-100 hover:bg-slate-200 rounded-md text-sm font-medium transition-colors">
                <Download size={16} /> Esporta
              </button>
              <label className="flex items-center gap-2 px-3 py-2 bg-slate-100 hover:bg-slate-200 rounded-md text-sm font-medium cursor-pointer transition-colors">
                <Upload size={16} /> Importa
                <input type="file" accept=".json" onChange={importaDati} className="hidden" />
              </label>
              <button onClick={svuotaPiano} className="flex items-center gap-2 px-3 py-2 bg-red-50 hover:bg-red-100 text-red-600 rounded-md text-sm font-medium transition-colors">
                <Trash2 size={16} /> Svuota
              </button>
            </div>
          </div>

          {/* BARRA DEGLI STRUMENTI (PENNELI) */}
          <div className="bg-slate-100 p-3 rounded-xl border border-slate-200 flex flex-col md:flex-row gap-4 items-center">
            <div className="flex items-center gap-2 text-sm font-semibold text-slate-600 mr-2">
              <span>Tavolozza:</span>
            </div>
            <div className="flex flex-wrap gap-2 flex-1">
              {attivita.map(att => (
                <button
                  key={att.id}
                  onClick={() => setStrumentoAttivo(att.id)}
                  className={`px-3 py-1.5 rounded-lg text-sm font-medium transition-all shadow-sm flex items-center gap-2 border-2 ${
                    strumentoAttivo === att.id 
                      ? 'ring-2 ring-offset-2 ring-blue-500 scale-105 shadow-md ' + att.border
                      : 'border-transparent hover:scale-105 opacity-80'
                  } ${att.color}`}
                >
                  {att.name}
                </button>
              ))}
              <div className="w-px h-8 bg-slate-300 mx-2"></div>
              <button
                onClick={() => setStrumentoAttivo('gomma')}
                className={`px-3 py-1.5 rounded-lg text-sm font-medium transition-all shadow-sm flex items-center gap-2 border-2 ${
                  strumentoAttivo === 'gomma' 
                    ? 'ring-2 ring-offset-2 ring-slate-500 border-slate-400 bg-white'
                    : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50 opacity-80'
                }`}
              >
                <Eraser size={16} /> Gomma
              </button>
            </div>
          </div>
        </div>
      </header>

      {/* MAIN CONTENT */}
      <main className="flex-1 max-w-7xl mx-auto w-full p-4 flex flex-col gap-6">
        
        {/* SELEZIONE GIORNO E ORARI */}
        <div className="flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center">
          <div className="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
            {GIORNI.map((giorno, idx) => (
              <button
                key={giorno}
                onClick={() => setGiornoSelezionato(idx)}
                className={`px-4 py-2 rounded-full whitespace-nowrap font-medium text-sm transition-colors ${
                  giornoSelezionato === idx
                    ? 'bg-slate-800 text-white shadow-md'
                    : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-100'
                }`}
              >
                {giorno}
              </button>
            ))}
          </div>

          {/* SELETTORE FLESSIBILITA' ORARI */}
          <div className="flex items-center gap-2 bg-white border border-slate-200 rounded-lg px-3 py-2 shadow-sm shrink-0">
            <Clock size={16} className="text-slate-500" />
            <span className="text-sm font-medium text-slate-600">Slot:</span>
            <select
              value={intervallo}
              onChange={(e) => setIntervallo(Number(e.target.value))}
              className="text-sm font-bold text-blue-600 bg-transparent focus:outline-none cursor-pointer"
            >
              <option value={60}>60 min</option>
              <option value={45}>45 min</option>
              <option value={30}>30 min</option>
              <option value={15}>15 min</option>
            </select>
          </div>
        </div>

        {/* ISTRUZIONI RAPIDE */}
        <div className="bg-blue-50 text-blue-800 p-3 rounded-lg flex items-center gap-3 text-sm border border-blue-100">
          <Info size={18} className="text-blue-500 shrink-0" />
          <p>
            Stai modificando <strong>{GIORNI[giornoSelezionato]}</strong>. 
            Strumento attivo: <strong className="bg-white px-2 py-0.5 rounded shadow-sm">{strumentoAttivo === 'gomma' ? 'Gomma' : attivitaCorrente?.name}</strong>. 
            Clicca o tieni premuto il mouse sulle celle della griglia per colorare.
          </p>
        </div>

        {/* GRIGLIA PIANO VASCA */}
        <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full border-collapse select-none">
              <thead>
                <tr>
                  <th className="sticky left-0 z-10 bg-slate-100 border-b border-r border-slate-200 p-3 w-24 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">
                    Orario
                  </th>
                  {corsie.map(corsia => (
                    <th key={corsia} className="bg-slate-50 border-b border-r border-slate-200 p-3 min-w-[120px] text-center text-sm font-bold text-slate-700">
                      Corsia {corsia}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {fasceOrarie.map(fascia => (
                  <tr key={fascia.id} className="hover:bg-slate-50/50">
                    <td className="sticky left-0 z-10 bg-slate-50/90 backdrop-blur-sm border-b border-r border-slate-200 p-3 text-sm font-semibold text-slate-600 text-center whitespace-nowrap shadow-[1px_0_0_0_rgba(226,232,240,1)]">
                      {fascia.label}
                    </td>
                    {corsie.map(corsia => {
                      const key = `${giornoSelezionato}-${fascia.id}-${corsia}`;
                      const attivitaId = piano[key];
                      const infoAttivita = attivita.find(a => a.id === attivitaId);
                      
                      return (
                        <td 
                          key={corsia} 
                          className="border-b border-r border-slate-200 p-1 h-10 cursor-crosshair transition-colors duration-75 relative group"
                          onMouseDown={() => handleMouseDown(fascia.id, corsia)}
                          onMouseEnter={() => handleMouseEnter(fascia.id, corsia)}
                        >
                          <div className={`w-full h-full rounded flex items-center justify-center p-1 text-xs font-semibold text-center transition-all ${
                            infoAttivita ? infoAttivita.color : 'bg-transparent hover:bg-slate-100'
                          }`}>
                            {infoAttivita ? infoAttivita.name : ''}
                          </div>
                          {/* Hint visivo al passaggio del mouse se cella vuota */}
                          {!infoAttivita && strumentoAttivo !== 'gomma' && (
                             <div className="absolute inset-1 rounded bg-slate-200 opacity-0 group-hover:opacity-30 pointer-events-none transition-opacity"></div>
                          )}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  );
}
